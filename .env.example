LLM_TYPE=gemini
LLM_AI_API_KEY=XXXXX-XXXXX-XXXXX-XXXXX
LLM_AI_MODEL=gemini-<version>-<model>-<subtype>
EMBEDDINGS_AI_MODEL=gemini-<version>-<model>-<subtype>
LLM_AI_TEMPERATURE=<float value between 0 and 1>
LANGUAGE=<language code>
AI_PERSONA=<AI persona description>
LOCAL_KNOWLEDGE_PATH=<path to local knowledge directory>
LOCAL_KNOWLEDGE_DOC_TYPES=<comma-separated list of file extensions>
# DEBUG: set to true or 1 to enable printing which agent (Analyzer/RAG/Simple)
# is used for each request. Defaults to false when omitted.
DEBUG=false
# MODE: set to "gui" for graphical interface or "terminal" for command-line chat.
# Defaults to "gui" when omitted.
MODE=gui

# --- OpenAI ---
# LLM_TYPE=openai
# LLM_AI_API_KEY=sk-...
# LLM_AI_MODEL=gpt-4o
# EMBEDDINGS_AI_MODEL=text-embedding-3-small
# LLM_AI_BASE_URL=               # leave blank for api.openai.com

# --- LM Studio ---
# LLM_TYPE=lmstudio
# LLM_AI_BASE_URL=http://localhost:1234/v1
# LLM_AI_MODEL=<model-name>
# EMBEDDINGS_AI_MODEL=<model-name>

# --- Ollama ---
# LLM_TYPE=ollama
# LLM_AI_BASE_URL=http://localhost:11434
# LLM_AI_MODEL=llama3
# EMBEDDINGS_AI_MODEL=nomic-embed-text

# --- Anthropic ---
# LLM_TYPE=anthropic
# LLM_AI_API_KEY=sk-ant-...
# LLM_AI_MODEL=claude-opus-4-6
# Note: Anthropic has no embeddings API — RAG is disabled when using this provider.
